<Window x:Class="WpfApp1.Page1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Управление MySQL таблицами"
        Height="600" Width="900"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Глобальные стили -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E0E0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3D" />
            <Setter Property="BorderBrush" Value="#505070" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="CaretBrush" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Focusable="False"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D3D" />
            <Setter Property="BorderBrush" Value="#505070" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="Margin" Value="0,0,0,5" />
            <Setter Property="Height" Value="30" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background" Value="#6200EE" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Margin" Value="5,5" />
            <Setter Property="Height" Value="40" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3700B3" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#03DAC5" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#03DAC5" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#028E7A" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#B00020" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#8B001A" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#1E1E2E" Margin="0,0,0,-100">
        <!-- Основной контейнер -->
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="0.3*" />
                <ColumnDefinition Width="0.7*" />
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ: Список таблиц -->
            <Border Grid.Column="0" Background="#25253A" CornerRadius="10" Padding="15">
                <StackPanel>
                    <TextBlock Text="Таблицы в БД" FontSize="18" FontWeight="SemiBold"
                               Foreground="#BB86FC" Margin="0,0,0,15"/>

                    <ListBox Name="ListBoxTables"
                             Background="#2D2D3D"
                             BorderBrush="#505070"
                             Foreground="White"
                             SelectionChanged="ListBoxTables_SelectionChanged"
                             Height="400" />

                    <Button Content="Обновить список"
                            Click="ButtonRefreshTables_Click"
                            Style="{StaticResource SecondaryButton}"
                            Margin="0,10,0,5"/>

                    <Button Content="Удалить таблицу"
                            Name="ButtonDeleteTable"
                            Click="ButtonDeleteTable_Click"
                            Style="{StaticResource DangerButton}"
                            IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- ПРАВАЯ ПАНЕЛЬ: Управление таблицей -->
            <Border Grid.Column="1" Background="#25253A" CornerRadius="10" Padding="20" Margin="15,0,0,0">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="Работа с таблицей" FontSize="18" FontWeight="SemiBold"
                                   Foreground="#BB86FC" Margin="0,0,0,20"/>

                        <!-- Имя таблицы -->
                        <TextBlock Text="Имя таблицы:" />
                        <TextBox Name="TextBoxTableName" Margin="0,0,0,15"/>

                        <!-- Первичный ключ -->
                        <TextBlock Text="Поле первичного ключа:" />
                        <TextBox Name="TextBoxPrimaryKey" Margin="0,0,0,15"/>

                        <!-- Список полей -->
                        <TextBlock Text="Поля таблицы:" Margin="0,0,0,10"/>
                        <ListView Name="ListViewFields" Height="200" Background="#2D2D3D"
                                  BorderBrush="#505070" Foreground="White">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Имя поля" DisplayMemberBinding="{Binding Name}" Width="150"/>
                                    <GridViewColumn Header="Тип" DisplayMemberBinding="{Binding Type}" Width="120"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Добавление нового поля -->
                        <Grid Margin="0,15,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="215*"/>
                                <ColumnDefinition Width="214*"/>
                                <ColumnDefinition Width="51*" />
                                <ColumnDefinition Width="Auto" MinWidth="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0" Name="TextBoxFieldName" Margin="0,10,0,10" />
                            <ComboBox Grid.Column="1" Foreground="Black" Name="ComboBoxFieldType" Margin="5,10,5,10">
                                <ComboBoxItem Content="Целочисленный (INT)" Tag="INT"/>
                                <ComboBoxItem Content="Вещественный (DOUBLE)" Tag="DOUBLE"/>
                                <ComboBoxItem Content="Текстовый (TEXT)" Tag="TEXT"/>
                                <ComboBoxItem Content="Дата/время (DATETIME)" Tag="DATETIME"/>
                            </ComboBox>
                            <Button Grid.Column="2" Content="+" Click="ButtonAddField_Click" Background="#03DAC5" Margin="6,5,6,5"/>
                            <Button Grid.Column="3" Content="-" Background="Red" Click="ButtoDeleteField_Click" Margin="5,5,5,5" />
                        </Grid>

                        <!-- Кнопки действий -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                            <Button Content="Создать таблицу"
                                    Name="ButtonCreateTable"
                                    Click="ButtonCreateTable_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="140" Margin="5,0"/>

                            <Button Content="Сохранить изменения"
                                    Name="ButtonUpdateTable"
                                    Click="ButtonUpdateTable_Click"
                                    Width="160" Margin="5,0"/>

                            <Button Content="Очистить форму"
                                    Click="ButtonClearForm_Click"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="130" Margin="5,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Window>